import React, { useEffect, useRef, useState, useCallback, useMemo } from 'react';
import { View, Text, StyleSheet, Pressable, Animated, Easing, Dimensions, PanResponder, TouchableOpacity } from 'react-native';
import { RotateCw } from 'lucide-react-native';
import { BOARD, BOARD_SIZE } from '../../data/monopolyBoard';
import PlayerToken from './PlayerToken';

// ========== ISOMETRIC CONFIG ==========
const ISO_RATIO = 0.5; // y squash ratio (true isometric ≈ 0.5)

function gridToIso(row, col, tileW, tileH) {
  const isoX = (col - row) * (tileW * 0.5);
  const isoY = (col + row) * (tileH * ISO_RATIO * 0.5);
  return { x: isoX, y: isoY };
}

function getTileGrid(index) {
  if (index <= 6) return { row: 7, col: index };
  if (index <= 13) return { row: 7 - (index - 6), col: 7 };
  if (index <= 20) return { row: 0, col: 7 - (index - 14) };
  return { row: index - 20, col: 0 };
}

function getBuildingEmoji(level) {
  return ['🏠', '🏘️', '🏢', '🏰'][level] || '🏠';
}

function getSpecialEmoji(type) {
  const map = { start: '🏁', jail: '🔒', chance: '⭐', tax: '💰', 'free-parking': '🅿️', 'go-to-jail': '🚔' };
  return map[type] || '';
}

function darkenColor(hex, factor) {
  if (!hex || hex.length < 7) return '#0A0A0A';
  const h = hex.replace('#', '');
  const r = Math.max(0, Math.floor(parseInt(h.substring(0, 2), 16) * factor));
  const g = Math.max(0, Math.floor(parseInt(h.substring(2, 4), 16) * factor));
  const b = Math.max(0, Math.floor(parseInt(h.substring(4, 6), 16) * factor));
  return `rgb(${r},${g},${b})`;
}

// ========== ISOMETRIC TILE ==========
function IsoTile({
  tile, isoX, isoY, tileW, tileH,
  players, isCurrentPlayerHere, isAnimTarget,
  property, ownerColor, onPress,
}) {
  const isLand = tile.type === 'land';
  const playersHere = players.filter((p) => p.position === tile.position && p.status !== 'bankrupt');
  const hasOwner = property && ownerColor;
  const buildingLevel = property?.level || 0;
  const heightOffset = isLand && property ? (buildingLevel + 1) * 4 : 0;

  const faceW = tileW - 2;
  const faceH = tileH * ISO_RATIO;
  const sideDepth = 6 + heightOffset;

  const tileColor = isLand ? (tile.color || '#444') : '#222';
  const topBg = isCurrentPlayerHere ? '#332D10'
    : isAnimTarget ? '#10331A'
    : '#181818';
  const topBorder = isCurrentPlayerHere ? '#FFD700'
    : isAnimTarget ? '#44FF44'
    : '#2A2A2A';

  return (
    <Pressable
      style={{
        position: 'absolute',
        left: isoX,
        top: isoY - heightOffset,
        width: tileW,
        height: faceH + sideDepth + 2,
        zIndex: Math.round(isoY + 100),
      }}
      onPress={() => onPress?.(tile)}
    >
      {/* Left side face */}
      <View style={{
        position: 'absolute',
        top: faceH - 1,
        left: 0,
        width: faceW / 2 + 1,
        height: sideDepth + 1,
        backgroundColor: isLand ? darkenColor(tileColor, 0.35) : '#0C0C0C',
        borderBottomLeftRadius: 3,
      }} />
      {/* Right side face */}
      <View style={{
        position: 'absolute',
        top: faceH - 1,
        left: faceW / 2,
        width: faceW / 2 + 1,
        height: sideDepth + 1,
        backgroundColor: isLand ? darkenColor(tileColor, 0.5) : '#0F0F0F',
        borderBottomRightRadius: 3,
      }} />

      {/* Top face */}
      <View style={{
        width: faceW,
        height: faceH,
        backgroundColor: topBg,
        borderWidth: 1,
        borderColor: topBorder,
        borderRadius: 3,
        overflow: 'hidden',
        justifyContent: 'center',
        alignItems: 'center',
        padding: 1,
      }}>
        {/* Color accent bar */}
        {isLand && (
          <View style={{
            position: 'absolute', top: 0, left: 0, right: 0, height: 3,
            backgroundColor: tileColor, borderTopLeftRadius: 2, borderTopRightRadius: 2,
          }} />
        )}

        {/* Owner flag */}
        {hasOwner && (
          <View style={{ position: 'absolute', top: 2, right: 2 }}>
            <View style={{
              width: 1, height: 10, backgroundColor: '#AAA',
              position: 'absolute', left: 0,
            }} />
            <View style={{
              width: 7, height: 5, backgroundColor: ownerColor,
              borderRadius: 1, marginLeft: 1,
            }} />
          </View>
        )}

        {/* Building/Emoji */}
        <Text style={{ fontSize: heightOffset > 8 ? 13 : 10 }}>
          {isLand
            ? (property ? getBuildingEmoji(buildingLevel) : '')
            : getSpecialEmoji(tile.type)
          }
        </Text>

        {/* Name */}
        <Text style={styles.tileName} numberOfLines={1}>{tile.name}</Text>

        {/* Price or stars */}
        {isLand && !property && (
          <Text style={styles.tilePrice}>฿{tile.price}</Text>
        )}
        {isLand && property && (
          <Text style={styles.tileStars}>{'★'.repeat(buildingLevel + 1)}</Text>
        )}

        {/* Player tokens */}
        {playersHere.length > 0 && (
          <View style={styles.tokenRow}>
            {playersHere.map((p) => (
              <View key={p.id} style={[styles.tokenDot, { backgroundColor: p.color }]} />
            ))}
          </View>
        )}
      </View>
    </Pressable>
  );
}

// ========== ANIMATED TOKEN ==========
function AnimatedToken({ color, tilePositions, fromPos, toPos, onDone }) {
  const progress = useRef(new Animated.Value(0)).current;
  const bounceY = useRef(new Animated.Value(0)).current;
  const shadowScale = useRef(new Animated.Value(1)).current;

  useEffect(() => {
    const path = [];
    let pos = fromPos;
    while (pos !== toPos) {
      pos = (pos + 1) % BOARD_SIZE;
      path.push(pos);
    }
    if (path.length === 0) { onDone?.(); return; }

    const stepDur = Math.max(100, 320 / path.length);
    const anims = path.map((_, i) =>
      Animated.parallel([
        Animated.timing(progress, {
          toValue: i + 1, duration: stepDur,
          easing: Easing.inOut(Easing.ease), useNativeDriver: false,
        }),
        Animated.sequence([
          Animated.parallel([
            Animated.timing(bounceY, { toValue: -20, duration: stepDur * 0.35, easing: Easing.out(Easing.quad), useNativeDriver: false }),
            Animated.timing(shadowScale, { toValue: 0.5, duration: stepDur * 0.35, useNativeDriver: false }),
          ]),
          Animated.parallel([
            Animated.timing(bounceY, { toValue: 0, duration: stepDur * 0.65, easing: Easing.bounce, useNativeDriver: false }),
            Animated.timing(shadowScale, { toValue: 1, duration: stepDur * 0.65, useNativeDriver: false }),
          ]),
        ]),
      ])
    );
    Animated.sequence(anims).start(() => onDone?.());
  }, [fromPos, toPos]);

  // Build path
  const allPos = [fromPos];
  let p = fromPos;
  while (p !== toPos) { p = (p + 1) % BOARD_SIZE; allPos.push(p); }
  if (allPos.length < 2 || !tilePositions[fromPos]) return null;

  const inp = allPos.map((_, i) => i);
  const xOut = allPos.map((pos) => (tilePositions[pos]?.cx || 0) - 12);
  const yOut = allPos.map((pos) => (tilePositions[pos]?.cy || 0) - 18);

  const animX = progress.interpolate({ inputRange: inp, outputRange: xOut, extrapolate: 'clamp' });
  const baseY = progress.interpolate({ inputRange: inp, outputRange: yOut, extrapolate: 'clamp' });
  const animY = Animated.add(baseY, bounceY);
  const shadowY = progress.interpolate({
    inputRange: inp,
    outputRange: yOut.map((y) => y + 22),
    extrapolate: 'clamp',
  });

  return (
    <>
      <Animated.View style={{
        position: 'absolute', width: 24, height: 8, borderRadius: 12,
        backgroundColor: 'rgba(0,0,0,0.35)', zIndex: 998,
        left: animX, top: shadowY,
        transform: [{ scaleX: shadowScale }, { scaleY: Animated.multiply(shadowScale, 0.4) }],
      }} />
      <Animated.View style={[styles.animToken, { backgroundColor: color, left: animX, top: animY }]}>
        <Text style={{ fontSize: 12 }}>🚶</Text>
      </Animated.View>
    </>
  );
}

// ========== MAIN BOARD VIEW ==========
export default function BoardView({
  players = {},
  properties = {},
  currentPlayerId,
  onTilePress,
  animatingPlayer,
  onAnimationDone,
}) {
  const screenW = Dimensions.get('window').width;
  const boardW = Math.min(screenW - 16, 440);
  const TILE_W = Math.floor(boardW / 8.5);
  const TILE_H = TILE_W;

  // 3D Rotation via PanResponder - subtle angles for better visibility
  const rotateZ = useRef(new Animated.Value(-10)).current;
  const rotateX = useRef(new Animated.Value(30)).current;
  const baseRotZ = useRef(-10);
  const baseRotX = useRef(30);

  const panResponder = useRef(
    PanResponder.create({
      onStartShouldSetPanResponder: () => true,
      onMoveShouldSetPanResponder: (_, { dx, dy }) => Math.abs(dx) > 5 || Math.abs(dy) > 5,
      onPanResponderMove: (_, { dx, dy }) => {
        rotateZ.setValue(baseRotZ.current + dx * 0.5);
        rotateX.setValue(Math.max(10, Math.min(80, baseRotX.current - dy * 0.3)));
      },
      onPanResponderRelease: (_, { dx, dy }) => {
        baseRotZ.current += dx * 0.5;
        baseRotX.current = Math.max(10, Math.min(80, baseRotX.current - dy * 0.3));
      },
    })
  ).current;

  const handleResetRotation = () => {
    baseRotZ.current = -10;
    baseRotX.current = 30;
    Animated.parallel([
      Animated.timing(rotateZ, { toValue: -10, duration: 400, easing: Easing.out(Easing.back(1.2)), useNativeDriver: false }),
      Animated.timing(rotateX, { toValue: 30, duration: 400, easing: Easing.out(Easing.back(1.2)), useNativeDriver: false }),
    ]).start();
  };

  // Isometric positions
  const tilePositions = useMemo(() => {
    const positions = {};
    const allIso = BOARD.map((tile) => {
      const { row, col } = getTileGrid(tile.position);
      return gridToIso(row, col, TILE_W, TILE_H);
    });
    const minX = Math.min(...allIso.map((p) => p.x));
    const minY = Math.min(...allIso.map((p) => p.y));
    const maxX = Math.max(...allIso.map((p) => p.x));

    const offsetX = (boardW - (maxX - minX + TILE_W)) / 2 - minX;
    const offsetY = 15 - minY;

    BOARD.forEach((tile) => {
      const { row, col } = getTileGrid(tile.position);
      const iso = gridToIso(row, col, TILE_W, TILE_H);
      const x = iso.x + offsetX;
      const y = iso.y + offsetY;
      positions[tile.position] = {
        x, y,
        cx: x + TILE_W / 2,
        cy: y + (TILE_H * ISO_RATIO) / 2,
      };
    });
    return positions;
  }, [boardW, TILE_W, TILE_H]);

  const totalH = useMemo(() => {
    const ys = Object.values(tilePositions).map((p) => p.y);
    return Math.max(...ys) + TILE_H * ISO_RATIO + 40;
  }, [tilePositions, TILE_H]);

  const playerList = Object.entries(players).map(([id, p]) => ({ id, ...p }));

  const interpRotX = rotateX.interpolate({ inputRange: [0, 90], outputRange: ['0deg', '90deg'] });
  const interpRotZ = rotateZ.interpolate({ inputRange: [-360, 360], outputRange: ['-360deg', '360deg'] });

  return (
    <View style={styles.boardContainer} {...panResponder.panHandlers}>
      {/* Reset rotation */}
      <TouchableOpacity style={styles.resetBtn} onPress={handleResetRotation} activeOpacity={0.7}>
        <RotateCw color="#FFD700" size={14} />
      </TouchableOpacity>

      {/* 3D transformed board */}
      <Animated.View style={[
        styles.perspectiveWrap,
        { transform: [{ perspective: 800 }, { rotateX: interpRotX }, { rotateZ: interpRotZ }] },
      ]}>
        <View style={[styles.boardInner, { width: boardW, height: totalH }]}>
          {/* Center decoration */}
          <View style={styles.centerFloor} pointerEvents="none">
            <Text style={styles.centerEmoji}>🎲</Text>
            <Text style={styles.centerText}>เศรษฐี</Text>
            <Text style={styles.centerSub}>MONOPOLY</Text>
          </View>

          {/* Ground shadow for depth */}
          <View style={[styles.groundShadow, {
            width: boardW * 0.6, height: totalH * 0.35,
            left: boardW * 0.2, top: totalH * 0.35,
          }]} />

          {/* All tiles */}
          {BOARD.map((tile) => {
            const pos = tilePositions[tile.position];
            if (!pos) return null;
            const isHere = playerList.some((p) => p.id === currentPlayerId && p.position === tile.position);
            const isAnimTarget = animatingPlayer?.to === tile.position;
            const prop = properties[tile.position];
            const ownerColor = prop ? players[prop.owner]?.color : null;

            return (
              <IsoTile
                key={tile.position}
                tile={tile}
                isoX={pos.x}
                isoY={pos.y}
                tileW={TILE_W}
                tileH={TILE_H}
                players={animatingPlayer ? playerList.filter((p) => p.id !== animatingPlayer.id) : playerList}
                isCurrentPlayerHere={isHere && !animatingPlayer}
                isAnimTarget={isAnimTarget}
                property={prop}
                ownerColor={ownerColor}
                onPress={onTilePress}
              />
            );
          })}

          {/* Animated walking token */}
          {animatingPlayer && (
            <AnimatedToken
              color={animatingPlayer.color}
              tilePositions={tilePositions}
              fromPos={animatingPlayer.from}
              toPos={animatingPlayer.to}
              onDone={onAnimationDone}
            />
          )}
        </View>
      </Animated.View>
    </View>
  );
}

// ========== STYLES ==========
const styles = StyleSheet.create({
  boardContainer: {
    flex: 1,
    justifyContent: 'center',
    alignItems: 'center',
  },
  perspectiveWrap: {
    justifyContent: 'center',
    alignItems: 'center',
  },
  resetBtn: {
    position: 'absolute',
    top: 8,
    right: 8,
    zIndex: 200,
    width: 34,
    height: 34,
    borderRadius: 17,
    backgroundColor: '#1A1A1A',
    justifyContent: 'center',
    alignItems: 'center',
    borderWidth: 1,
    borderColor: '#FFD70060',
  },
  boardInner: {
    alignSelf: 'center',
    overflow: 'visible',
  },
  groundShadow: {
    position: 'absolute',
    backgroundColor: 'rgba(255,215,0,0.02)',
    borderRadius: 100,
  },

  // Center
  centerFloor: {
    position: 'absolute',
    top: '28%',
    left: '22%',
    right: '22%',
    bottom: '22%',
    justifyContent: 'center',
    alignItems: 'center',
    backgroundColor: '#0C0C0C',
    borderRadius: 16,
    borderWidth: 1,
    borderColor: '#1A1A1A',
  },
  centerEmoji: { fontSize: 26, marginBottom: 2 },
  centerText: {
    color: '#FFD700',
    fontSize: 15,
    fontWeight: 'bold',
    textShadowColor: 'rgba(255,215,0,0.3)',
    textShadowOffset: { width: 0, height: 2 },
    textShadowRadius: 8,
  },
  centerSub: { color: '#444', fontSize: 7, letterSpacing: 4, marginTop: 2 },

  // Tile content
  tileName: { color: '#888', fontSize: 5, textAlign: 'center', lineHeight: 7 },
  tilePrice: { color: '#FFD700', fontSize: 5, fontWeight: 'bold' },
  tileStars: { color: '#FFD700', fontSize: 5 },
  tokenRow: { flexDirection: 'row', gap: 2, marginTop: 1 },
  tokenDot: {
    width: 7, height: 7, borderRadius: 4,
    borderWidth: 1, borderColor: '#FFF',
  },

  // Animated token
  animToken: {
    position: 'absolute',
    width: 24,
    height: 24,
    borderRadius: 12,
    borderWidth: 2,
    borderColor: '#FFF',
    zIndex: 999,
    justifyContent: 'center',
    alignItems: 'center',
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 4 },
    shadowOpacity: 0.7,
    shadowRadius: 8,
    elevation: 12,
  },
});
