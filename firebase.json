{
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/selection-preview",
        "destination": "/selection-preview.html"
      },
      {
        "source": "/domino",
        "destination": "/domino.html"
      },
      {
        "source": "/textbox-preview",
        "destination": "/textbox-preview.html"
      },
      {
        "source": "/soundboard-display",
        "destination": "/soundboard-display.html"
      },
      {
        "source": "/music-player-display",
        "destination": "/music-player-display.html"
      },
      {
        "source": "/music-player-config",
        "destination": "/music-player-config.html"
      },
      {
        "source": "/soundboard-controller",
        "destination": "/soundboard-controller.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
